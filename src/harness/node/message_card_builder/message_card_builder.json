{
    "type": "message_card_builder",
    "name": "消息卡片构建器",
    "description": "将文本和角色包装成标准 MessageList 格式",
    "color": "#3498DB",
    "inputs": [
        {
            "name": "content",
            "type": "string",
            "description": "消息内容",
            "required": true
        },
        {
            "name": "role",
            "type": "string",
            "description": "消息角色 (system/user/assistant)",
