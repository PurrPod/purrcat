{
    "type": "template_renderer",
    "name": "模板渲染器",
    "color": "#E67E22",
    "inputs": [
        { "name": "template", "type": "string", "port_type": "static" },
        {
            "name": "dynamic_vars", "type": "any", "port_type": "dynamic",
            "dynamic_rules": {
                "watch_config": "template",
                "method": "regex",
                "pattern": "\\{\\{\\s*([a-zA-Z0-9_]+)\\s*\\}\\}"
            }
        }
    ],
    "outputs": [
        { "name": "rendered_text", "type": "string", "port_type": "static" }
    ],
    "config": [
        { "name": "template", "type": "textarea", "label": "Jinja2 模板" }
    ]
}