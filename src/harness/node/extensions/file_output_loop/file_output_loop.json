{
    "type": "file_output_loop",
    "name": "文件输出循环",
    "description": "封装思考->调用工具->验收的完整循环逻辑，最终输出一个文件到沙盒里",
    "color": "#16A085",
    "inputs": [
        {
            "name": "messages",
            "type": "MessageList",
            "description": "消息上下文",
            "required": true
        },
        {
            "name": "file_path",
            "type": "string",
            "description": "动态传入的文件路径",
            "required": false
        }
    ],
    "outputs": [
        {
            "name": "messages",
            "type": "MessageList",
            "description": "完整的消息历史"
        },
        {
            "name": "summary",
            "type": "string",
            "description": "任务完成的总结信息"
        }
    ],
    "config": [
        {
            "name": "file_path",
            "type": "string",
            "label": "输出文件路径",
            "default": "",
            "description": "沙盒内的绝对路径，必须以 /agent_vm 开头，否则任务无效"
        }
    ]
}