{
    "type": "message_card_builder",
    "name": "消息卡片构建器",
    "description": "将文本和角色包装成标准 MessageList 格式",
    "color": "#3498DB",
    "inputs": [
        {
            "name": "content",
            "type": "string",
            "port_type": "static",
            "description": "消息内容",
            "required": true
        },
        {
            "name": "role",
            "type": "string",
            "port_type": "static",
            "description": "消息角色 (system/user/assistant)",
            "required": false
        },
        {
            "name": "trigger",
            "type": "any",
            "port_type": "static",
            "description": "触发信号（可选）。如果不连线，节点将在开局自动执行；如果连线，将等待收到上游数据/信号后再执行。",
            "required": false
        }
    ],
    "outputs": [
        {
            "name": "message_list",
            "type": "array",
            "port_type": "static",
            "description": "标准消息列表"
        }
    ],
    "config": [
        {
            "name": "content",
            "type": "string",
            "label": "消息内容",
            "default": ""
        },
        {
            "name": "role",
            "type": "string",
            "label": "消息角色",
            "default": "user"
        }
    ]
}