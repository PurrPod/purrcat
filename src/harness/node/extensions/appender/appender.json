        {
            "name": "append_list",
            "type": "array",
            "port_type": "static",
            "description": "要追加的列表"
        }
    ],
    "outputs": [
        {
            "name": "merged_list",
            "type": "array",
            "port_type": "static",
            "description": "合并后的列表"
        }
    ],
    "config": []
}