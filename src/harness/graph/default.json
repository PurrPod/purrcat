{
    "name": "default",
    "description": "默认工作流：全局输入 → 拼装消息 → LLM循环思考 → 全局输出",
    "required_inputs": {
        "prompt": "核心任务提示词，告知工作流具体要完成什么任务",
        "target_file": "最终生成文件的路径"
    },
    "nodes": [
        {"id": "node_input", "type": "task_input", "data": {"dynamic_inputs": [{"key": "prompt", "desc": "any"}, {"key": "target_file", "desc": "any"}]}},
        {"id": "node_sys_msg", "type": "message_card_builder", "data": {"role": "system", "content": "你是一个优秀的AI任务助手，请利用工具高效完成任务。"}},
        {"id": "node_user_msg", "type": "message_card_builder", "data": {"role": "user"}},
        {"id": "node_appender", "type": "appender"},
        {"id": "node_loop", "type": "file_output_loop", "data": {"file_path": ""}},
        {"id": "node_output", "type": "task_output", "data": {"dynamic_inputs": [{"key": "task_result", "desc": "any"}]}}
    ],
    "edges": [
        {"source": "node_input", "target": "node_user_msg", "sourceHandle": "prompt", "targetHandle": "content"},
        {"source": "node_input", "target": "node_loop", "sourceHandle": "target_file", "targetHandle": "file_path"},
        {"source": "node_sys_msg", "target": "node_appender", "sourceHandle": "message_list", "targetHandle": "base_list"},
        {"source": "node_user_msg", "target": "node_appender", "sourceHandle": "message_list", "targetHandle": "append_list"},
        {"source": "node_appender", "target": "node_loop", "sourceHandle": "merged_list", "targetHandle": "messages"},
        {"source": "node_loop", "target": "node_output", "sourceHandle": "summary", "targetHandle": "task_result"}
    ]
}