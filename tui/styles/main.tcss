/* 全局透明背景，让终端原生的颜色透过来 */
Screen {
    background: transparent;
    color: #e4e4e7;
}

/* 主容器：撑满全屏 */
#main-layout {
    layout: horizontal;
    width: 100%;
    height: 100%;
}

/* 左侧主区：按比例占据 4 份 */
#left-pane {
    width: 4fr;
    height: 100%;
    layout: vertical;
    padding: 0 1 0 0;
}

/* === 左侧 1/5：顶部容器 === */
#top-zone {
    height: 1fr;
    border: round #d97706; /* 高级感的圆角边框，采用类似 Claude 的橙色 */
    layout: horizontal;
    padding: 1 2;
    margin-bottom: 1;
}

#cat-ascii {
    width: 15;
    color: #d97706; /* 小猫使用强调色 */
    text-style: bold;
    content-align: left middle;
}

#status-container {
    width: 1fr;
    layout: vertical;
    align: left middle;
}

#version-text {
    color: #d97706;
    text-style: bold;
}

#sub-status {
    color: #a1a1aa;
    margin-bottom: 1;
}

/* 修改自带的进度条样式，使其扁平且符合配色 */
ProgressBar {
    height: 1;
}
ProgressBar > Bar {
    color: #d97706;
    background: #27272a;
}


#input-row {
    layout: horizontal;
    height: 1fr;
    align: left middle;
}

/* --- tui/styles/main.tcss 局部更新 --- */

#chat-zone {
    height: 3fr;
    border: round #52525b;
    border-title-color: #a1a1aa;
    border-title-align: left; /* 控制缺口标题在左上角 */
    padding: 1 2;
    overflow-y: auto;
    margin-bottom: 1;
    scrollbar-size: 1 1;
    scrollbar-color: #52525b;
}

#input-zone {
    height: 1fr;
    border: round #52525b;
    border-title-color: #a1a1aa;
    border-title-align: left; /* 控制缺口标题在左上角 */
    padding: 1 2;
    layout: vertical;
}

/* 适配 Textual 的 TextArea */
#chat-input {
    width: 1fr;
    height: 100%;
    border: none;
    background: transparent;
    color: #e4e4e7;
    padding: 0;
}

#chat-input:focus {
    border: none;
}

#shortcut-hint {
    height: 1;
    color: #52525b;
    text-align: right;
    width: 100%;
}

/* === 右侧侧边栏：按比例占据 1 份 === */
#right-pane {
    width: 1fr;
    height: 100%;
    border: round #52525b;
    layout: vertical;
    padding: 1 2;
}

.sidebar-title {
    color: #d97706;
    text-style: bold;
    margin-bottom: 1;
    width: 100%;
    text-align: center;
}

ListView {
    background: transparent;
    border: none;
}

ListItem {
    background: transparent;
    padding: 0;
    border: none;
}

.nav-item {
    color: #a1a1aa;
    padding: 1;
}

ListItem:hover .nav-item {
    color: #e4e4e7;
}

ListItem.--highlight .nav-item {
    color: #d97706;
    text-style: bold;
}


.role-user {
    color: #71717a;
    text-style: none;
}

.role-system {
    color: #ef4444;
}

.role-ai {
    color: #e4e4e7;
    text-style: bold;
}

ChatMessage {
    margin-bottom: 1;
    height: auto;
    width: 100%;
}

Markdown {
    background: transparent;
    color: #e4e4e7;
    margin-left: 2;
    width: 100%; /* 锁死最大宽度，让文字引擎乖乖换行 */
}

#prompt-char {
    width: 2;
    color: #d97706;
    text-style: bold;
    content-align: center middle;
}

/* 专注模式隐藏侧边栏 */
.focus-mode #right-pane {
    display: none;
}

.focus-mode #left-pane {
    width: 100%;
    padding-right: 0;
}
.tool-header {
    color: #d97706; /* 强调色，标识工具发起 */
    margin-top: 1;
    margin-left: 2;
}

.tool-scanning {
    color: #a1a1aa; /* 扫面时的等待态（次要文本色） */
    margin-left: 2;
}

.tool-result {
    color: #f4f4f5; /* 完成并回填数据的状态（主文本色） */
    margin-bottom: 1;
    margin-left: 2;
}

/* 修复工具调用区块空白问题 */
ToolCallWidget {
    height: auto;
    width: 100%;
}