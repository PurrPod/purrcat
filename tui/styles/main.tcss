/* 完全透明，融入原生终端 */
Screen {
    background: transparent;
}

#main-content {
    width: 100%;
    height: 100%;
    background: transparent;
}

/* 聊天历史记录区 */
#chat-history {
    height: 1fr;
    padding: 0 1;
    overflow-y: auto;
    scrollbar-size: 1 1;
}

#welcome-pet {
    margin-top: 1;
    margin-bottom: 2;
    color: #888888;
}

/* 消息气泡（无边框，仅通过颜色区分） */
ChatMessage {
    margin-bottom: 1;
    padding: 0;
    height: auto;
}

.role-user {
    color: #a3e635; /* 亮绿色，类似 Claude Code 用户的标识 */
    text-style: bold;
    margin-bottom: 1;
}

.role-ai {
    color: #88aaee; /* 亮蓝色，AI 的标识 */
    text-style: bold;
    margin-bottom: 1;
}

/* 底部命令输入区 */
#input-area {
    height: auto;
    min-height: 1;
    max-height: 10;
    padding: 1 1;
}

#prompt-char {
    width: 3;
    color: #f5a623; /* 亮橙色提示符 */
    text-style: bold;
}

#chat-input {
    width: 1fr;
    border: none;
    background: transparent;
    padding: 0;
}

#chat-input:focus {
    border: none;
}